{
  "name": "mandi-connect",
  "version": "1.0.0",
  "description": "Mandi-Connect Root",
  "scripts": {
    "start": "npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npx -y serve@latest -l 3000 --no-port-switching .",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
