{
  "name": "mandi-connect",
  "version": "1.0.0",
  "description": "Mandi-Connect Root",
  "scripts": {
    "start": "npm run dev",
    "dev:backend": "cd backend && cross-env PORT=3002 npm run dev",
    "dev:frontend": "cd frontend && npx -y serve@latest -l 3000 --no-port-switching .",
    "dev:react": "cd frontend-react && npm run dev",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:react\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0"
  }
}
